{
  "version": 2,
  "buildCommand": "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/university-portal run build && node api/build.mjs",
  "outputDirectory": "artifacts/university-portal/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/handler" },
    { "source": "/((?!_vercel|api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/handler.mjs": {
      "maxDuration": 30
    }
  }
}
