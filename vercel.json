{
  "version": 2,
  "buildCommand": "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/university-portal run build",
  "outputDirectory": "artifacts/university-portal/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!_vercel|api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}
