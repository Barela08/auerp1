# Required — PostgreSQL connection string
# Use Neon (https://neon.tech) or Supabase (https://supabase.com) for serverless-compatible Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Required — Random secret string for session encryption (min 32 chars)
# Generate with: openssl rand -hex 32
SESSION_SECRET=your-super-secret-session-key-minimum-32-characters

# Set automatically by Vercel — do not change
NODE_ENV=production
